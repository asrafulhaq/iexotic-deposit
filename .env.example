# Stripe keys — use sk_test_ during dev, swap to sk_live_ for production
STRIPE_SECRET_KEY=sk_test_

# Amount in cents — $1,000 = 100000 | $500 = 50000 | $300 = 30000
DEPOSIT_AMOUNT_CENTS=400000

# Your deployed Vercel URL — no trailing slash
SITE_URL=https://your-project.vercel.app

# Slack Incoming Webhook URL (api.slack.com/apps → Incoming Webhooks)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Stripe webhook signing secret — whsec_... from Stripe Dashboard → Webhooks
# Add this after first deployment when you register the webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_
